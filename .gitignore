# dependencies
/node_modules

# next.js
/.next
/out

# content store + media (durable but local-only; never committed)
/data

# env (.env.example is committed; .env is not)
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# local agent worktrees (fix branches, throwaway checkouts)
/.claude/worktrees

# playwright-cli downloads (console logs, page dumps, screenshots — local-only)
/.playwright-cli

# local Claude Code config (machine-specific permissions / env — never commit)
/.claude/settings.local.json
/.claude/settings.json

# OS / editor cruft
.DS_Store
*.local
