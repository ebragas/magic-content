# Copy to .env and fill in. APIFY_TOKEN + GEMINI_API_KEY are required; ANTHROPIC_API_KEY
# is optional (without it the FAQ-extraction leg is a safe no-op, like the other ports).

# Apify — Instagram scraping (https://console.apify.com/account/integrations)
APIFY_TOKEN=your-apify-token

# Google Gemini — transcription + video analysis (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Anthropic (Claude) — language tasks: FAQ clustering (extractFaqs) + Draft generation
# (ADR-0008). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
